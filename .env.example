# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://uns:unspassword@postgres:5432/uns_explorer
POSTGRES_USER=uns
POSTGRES_PASSWORD=unspassword

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
CREDENTIALS_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_base64_32

# ── Application ───────────────────────────────────────────────────────────────
RUST_LOG=info
# Base URL used to build OAuth redirect URIs — set to your public domain
# Example: https://ide.example.com
APP_BASE_URL=http://localhost

# ── LinkedIn OAuth (optional) ─────────────────────────────────────────────────
# Create an app at https://www.linkedin.com/developers/
# Leave blank to disable LinkedIn login
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Email Verification via SMTP (optional) ────────────────────────────────────
# Leave SMTP_HOST blank to disable email verification on registration
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
# If set, a notification email is sent to this address whenever a new account is created
SMTP_NEW_ACCOUNT_NOTIFY_EMAIL=
